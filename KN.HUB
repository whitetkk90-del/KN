-- Aba ESP
local ESPTab = Window:CreateTab("👁️ ESP", 4483362458)

ESPTab:CreateToggle({
    Name = "ESP Players",
    CurrentValue = false,
    Flag = "ESPPlayers",
    Callback = function(v)
        if v then
            spawn(function()
                while wait(1) do
                    for _, p in pairs(game.Players:GetPlayers()) do
                        if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                            if not p.Character.Head:FindFirstChild("ESP") then
                                local b = Instance.new("BillboardGui")
                                b.Name = "ESP"
                                b.Parent = p.Character.Head
                                b.Size = UDim2.new(0, 150, 0, 40)
                                b.StudsOffset = Vector3.new(0, 2, 0)
                                b.AlwaysOnTop = true
                                
                                local t = Instance.new("TextLabel")
                                t.Parent = b
                                t.Size = UDim2.new(1, 0, 1, 0)
                                t.BackgroundTransparency = 1
                                t.Text = p.Name .. " [" .. math.floor(p.Character.Humanoid.Health) .. "HP]"
                                t.TextColor3 = Color3.new(0, 1, 0)
                                t.TextStrokeTransparency = 0
                                t.TextScaled = true
                            end
                        end
                    end
                end
            end)
        else
            for _, p in pairs(game.Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("Head") and p.Character.Head:FindFirstChild("ESP") then
                    p.Character.Head.ESP:Destroy()
                end
            end
        end
    end
})

ESPTab:CreateToggle({
    Name = "ESP Chests",
    CurrentValue = false,
    Flag = "ESPChests",
    Callback = function(v)
        if v then
            spawn(function()
                while wait(1) do
                    for _, chest in pairs(getChests()) do
                        if chest and not chest:FindFirstChild("ESP") then
                            local b = Instance.new("BillboardGui")
                            b.Name = "ESP"
                            b.Parent = chest
                            b.Size = UDim2.new(0, 100, 0, 30)
                            b.StudsOffset = Vector3.new(0, 2, 0)
                            b.AlwaysOnTop = true
                            
                            local t = Instance.new("TextLabel")
                            t.Parent = b
                            t.Size = UDim2.new(1, 0, 1, 0)
                            t.BackgroundTransparency = 1
                            t.Text = "📦 Baú"
                            t.TextColor3 = Color3.new(1, 1, 0)
                            t.TextScaled = true
                        end
                    end
                end
            end)
        else
            for _, chest in pairs(getChests()) do
                if chest and chest:FindFirstChild("ESP") then
                    chest.ESP:Destroy()
                end
            end
        end
    end
})

