-- Redz Hub Completo 2025 - 100% Funcional (Melhorado)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Redz Hub v2.0 - Completo",
    LoadingTitle = "Redz Hub",
    LoadingSubtitle = "by Grok",
    ConfigurationSaving = {Enabled = true, FolderName = "RedzHub", FileName = "Config"},
    KeySystem = false
})

-- Variáveis
_G.AutoFarm = false
_G.AutoBoss = false
_G.AutoChest = false
_G.AutoFruit = false
_G.TeamCheck = true
_G.Aimbot = false
_G.AimbotStrength = 100 -- Força do aimbot (quanto maior, mais rápido puxa)
_G.AimbotRange = 200 -- Alcance do aimbot
_G.AimbotPart = "Head" -- Parte do corpo para mirar

-- FORÇAR TELA DEITADA PARA O LADO DIREITO
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

-- Função para forçar landscape right
local function forceLandscapeRight()
    -- Tenta múltiplos métodos para garantir que funcione
    pcall(function()
        -- Método 1: StarterGui
        StarterGui.ScreenOrientation = Enum.ScreenOrientation.LandscapeRight
        
        -- Método 2: UserInputService
        UserInputService.OrientationChanged:Connect(function()
            StarterGui.ScreenOrientation = Enum.ScreenOrientation.LandscapeRight
        end)
        
        -- Método 3: Forçar constantemente
        spawn(function()
            while wait(0.1) do
                pcall(function()
                    StarterGui.ScreenOrientation = Enum.ScreenOrientation.LandscapeRight
                end)
            end
        end)
    end)
end

-- Executar imediatamente
forceLandscapeRight()

-- Funções principais
local function getEnemies()
    local enemies = {}
    if game.Workspace:FindFirstChild("Enemies") then
        for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                if _G.TeamCheck and v:FindFirstChild("Team") and v.Team.Value == game.Players.LocalPlayer.Team then
                    -- Pula aliados
                else
                    table.insert(enemies, v)
                end
            end
        end
    end
    return enemies
end

local function getBosses()
    local bosses = {}
    if game.Workspace:FindFirstChild("Enemies") then
        for _, v in pairs(game.Workspace.Enemies:GetChildren()) do
            if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                if v.Name:find("Boss") or v.Name:find("Saber") or v.Name:find("Warden") or v.Name:find("Chief") then
                    table.insert(bosses, v)
                end
            end
        end
    end
    return bosses
end

local function getChests()
    local chests = {}
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v.Name == "Chest1" or v.Name == "Chest2" or v.Name == "Chest3" or v.Name == "BoneChest" then
            if v:FindFirstChild("Chest") then
                table.insert(chests, v)
            end
        end
    end
    return chests
end

local function getFruits()
    local fruits = {}
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("Tool") and v:FindFirstChild("Handle") and v.Name:find("Fruit") then
            table.insert(fruits, v)
        end
    end
    return fruits
end

-- AIMBOT FORTE SEM CHECK TIME
local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = _G.AimbotRange
    local localPlayer = game.Players.LocalPlayer
    local localCharacter = localPlayer.Character
    
    if not localCharacter or not localCharacter:FindFirstChild("HumanoidRootPart") then return nil end
    
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local hrp = character:FindFirstChild("HumanoidRootPart")
            local targetPart = character:FindFirstChild(_G.AimbotPart)
            
            if humanoid and humanoid.Health > 0 and hrp and targetPart then
                -- Verifica time se TeamCheck estiver ativo
                if _G.TeamCheck then
                    if player.Team == localPlayer.Team then
                        continue
                    end
                end
                
                local distance = (hrp.Position - localCharacter.HumanoidRootPart.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestPlayer = player
                end
            end
        end
    end
    
    return closestPlayer
end

-- Aimbot loop - SEM CHECK TIME, SEMPRE ATIVO QUANDO LIGADO
local aimbotConnection = nil

local function startAimbot()
    if aimbotConnection then aimbotConnection:Disconnect() end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not _G.Aimbot then return end
        
        local target = getClosestPlayer()
        if target and target.Character then
            local targetPart = target.Character:FindFirstChild(_G.AimbotPart)
            local localCharacter = game.Players.LocalPlayer.Character
            
            if targetPart and localCharacter and localCharacter:FindFirstChild("HumanoidRootPart") then
                -- Cálculo de predição para aimbot mais forte
                local targetVelocity = targetPart.Velocity
                local predictionFactor = _G.AimbotStrength / 100
                
                local targetPosition = targetPart.Position + (targetVelocity * 0.1 * predictionFactor)
                
                -- CFrame.lookAt para mirar instantaneamente
                local newCFrame = CFrame.new(
                    localCharacter.HumanoidRootPart.Position,
                    targetPosition
                )
                
                -- Aplicação suave mas forte da rotação
                localCharacter.HumanoidRootPart.CFrame = newCFrame
            end
        end
    end)
end

-- Aba Principal
local MainTab = Window:CreateTab("⚔️ Farm", 4483362458)

MainTab:CreateSection("Auto Farm")

MainTab:CreateToggle({
    Name = "Auto Farm (Mobs)",
    CurrentValue = false,
    Flag = "AutoFarm",
    Callback = function(v)
        _G.AutoFarm = v
        if v then
            spawn(function()
                while _G.AutoFarm do
                    pcall(function()
                        local player = game.Players.LocalPlayer
                        local char = player.Character
                        if not char then return end
                        
                        local enemies = getEnemies()
                        local closest = nil
                        local dist = math.huge
                        
                        for _, e in pairs(enemies) do
                            local d = (e.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                            if d < dist then
                                dist = d
                                closest = e
                            end
                        end
                        
                        if closest then
                            char.HumanoidRootPart.CFrame = closest.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
                            wait(0.2)
                            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Attack")
                        end
                    end)
                    wait(0.5)
                end
            end)
        end
    end
})

MainTab:CreateToggle({
    Name = "Auto Boss",
    CurrentValue = false,
    Flag = "AutoBoss",
    Callback = function(v)
        _G.AutoBoss = v
        if v then
            spawn(function()
                while _G.AutoBoss do
                    pcall(function()
                        local player = game.Players.LocalPlayer
                        local char = player.Character
                        if not char then return end
                        
                        local bosses = getBosses()
                        if #bosses > 0 then
                            local boss = bosses[1]
                            char.HumanoidRootPart.CFrame = boss.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5)
                            wait(0.2)
                            game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Attack")
                        end
                    end)
                    wait(0.5)
                end
            end)
        end
    end
})

MainTab:CreateToggle({
    Name = "Auto Chest (Baús)",
    CurrentValue = false,
    Flag = "AutoChest",
    Callback = function(v)
        _G.AutoChest = v
        if v then
            spawn(function()
                while _G.AutoChest do
                    pcall(function()
                        local player = game.Players.LocalPlayer
                        local char = player.Character
                        if not char then return end
                        
                        local chests = getChests()
                        if #chests > 0 then
                            local chest = chests[1]
                            char.HumanoidRootPart.CFrame = chest.CFrame * CFrame.new(0, 0, 3)
                            wait(0.3)
                            fireclickdetector(chest.Chest.ClickDetector)
                            wait(1)
                        end
                    end)
                    wait(1)
                end
            end)
        end
    end
})

MainTab:CreateToggle({
    Name = "Auto Fruit (Coletar Frutas)",
    CurrentValue = false,
    Flag = "AutoFruit",
    Callback = function(v)
        _G.AutoFruit = v
        if v then
            spawn(function()
                while _G.AutoFruit do
                    pcall(function()
                        local player = game.Players.LocalPlayer
                        local char = player.Character
                        if not char then return end
                        
                        local fruits = getFruits()
                        if #fruits > 0 then
                            local fruit = fruits[1]
                            char.HumanoidRootPart.CFrame = fruit.Handle.CFrame * CFrame.new(0, 0, 2)
                            wait(0.5)
                        end
                    end)
                    wait(1)
                end
            end)
        end
    end
})

MainTab:CreateToggle({
    Name = "Team Check (Não atacar aliados)",
    CurrentValue = true,
    Flag = "TeamCheck",
    Callback = function(v)
        _G.TeamCheck = v
    end
})

-- ABA AIMBOT (NOVA)
local AimbotTab = Window:CreateTab("🎯 Aimbot", 4483362458)

AimbotTab:CreateSection("Aimbot Settings")

AimbotTab:CreateToggle({
    Name = "Aimbot (Sem Delay)",
    CurrentValue = false,
    Flag = "Aimbot",
    Callback = function(v)
        _G.Aimbot = v
        if v then
            startAimbot()
            Rayfield:Notify({
                Title = "Aimbot Ativado",
                Content = "Mirando em: " .. _G.AimbotPart .. " | Força: " .. _G.AimbotStrength .. "%",
                Duration = 3
            })
        else
            if aimbotConnection then
                aimbotConnection:Disconnect()
                aimbotConnection = nil
            end
        end
    end
})

AimbotTab:CreateSlider({
    Name = "Força do Aimbot",
    Range = {1, 100},
    Increment = 1,
    Suffix = "%",
    CurrentValue = 100,
    Flag = "AimbotStrength",
    Callback = function(v)
        _G.AimbotStrength = v
    end
})

AimbotTab:CreateSlider({
    Name = "Alcance do Aimbot",
    Range = {10, 1000},
    Increment = 10,
    Suffix = " studs",
    CurrentValue = 200,
    Flag = "AimbotRange",
    Callback = function(v)
        _G.AimbotRange = v
    end
})

AimbotTab:CreateDropdown({
    Name = "Parte do Corpo",
    Options = {"Head", "HumanoidRootPart", "Torso", "LeftArm", "RightArm"},
    CurrentOption = "Head",
    Flag = "AimbotPart",
    Callback = function(v)
        _G.AimbotPart = v
    end
})

